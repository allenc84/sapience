# Copy to .env and fill in. .env is gitignored.

# Who the memory system serves. Shown in tool descriptions and used to frame
# synthesized briefs, calibration patterns, and bias maps.
MEMORY_USER_CONTEXT="Jane Doe, founder of Acme"

# Required: OpenAI key for embeddings.
OPENAI_API_KEY=sk-proj-...

# Required for get_context_brief / consolidation / calibration (Claude synthesis).
ANTHROPIC_API_KEY=sk-ant-...

# Judgment-ledger domains (comma-separated). Default: predictions,decisions,commitments.
# LEDGER_DOMAINS="investments,team-management,strategic-bets"

# Optional: where Sapience stores its data (vector DB, ledger, review state).
# Defaults to a per-user OS data dir. Set this to keep everything in one place.
# SAPIENCE_DATA_DIR=/absolute/path/to/sapience-data
# Or override individual stores:
# MEMORY_DB_PATH=/absolute/path/to/chroma_db
# LEDGER_DB_PATH=/absolute/path/to/ledger.db
